    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/celine-eu#AdminCost -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#AdminCost">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://w3id.org/celine-eu#CostType"/>
        <rdfs:comment>Overhead and management costs for operating the REC.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <skos:prefLabel>Administrative Cost</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/celine-eu#CostType"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#Automated -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#Automated">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://w3id.org/celine-eu#CommitmentMode"/>
        <rdfs:comment>Commitment fulfilled automatically by a smart device or control system, without manual intervention from the member.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <skos:prefLabel>Automated</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/celine-eu#CommitmentMode"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#CommitmentMode -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#CommitmentMode">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <terms:description>Classification of how a flexibility commitment is activated.</terms:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <rdfs:label>Commitment Mode</rdfs:label>
        <skos:prefLabel>Commitment Mode</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#CostType -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#CostType">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <terms:description>Classification of cost voices within a SettlementRun.</terms:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <rdfs:label>Cost Type</rdfs:label>
        <skos:prefLabel>Cost Type</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#Debt -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#Debt">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://w3id.org/celine-eu#CostType"/>
        <rdfs:comment>Outstanding obligation carried forward from a previous settlement period.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <skos:prefLabel>Debt</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/celine-eu#CostType"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#Fee -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#Fee">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://w3id.org/celine-eu#CostType"/>
        <rdfs:comment>Platform, service or regulatory fee charged to the community.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <skos:prefLabel>Fee</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/celine-eu#CostType"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#FlexDown -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#FlexDown">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://w3id.org/celine-eu#FlexibilityDirection"/>
        <rdfs:comment>Decrease community net consumption: reduce load or increase local generation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <skos:prefLabel>Flex Down</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/celine-eu#FlexibilityDirection"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#FlexUp -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#FlexUp">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://w3id.org/celine-eu#FlexibilityDirection"/>
        <rdfs:comment>Increase community net consumption: increase load or reduce local generation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <skos:prefLabel>Flex Up</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/celine-eu#FlexibilityDirection"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#FlexibilityDirection -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#FlexibilityDirection">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <terms:description>Direction of the flexibility commitment relative to the community baseline.</terms:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <rdfs:label>Flexibility Direction</rdfs:label>
        <skos:prefLabel>Flexibility Direction</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/celine-eu#Voluntary -->


    <owl:NamedIndividual rdf:about="https://w3id.org/celine-eu#Voluntary">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:inScheme rdf:resource="https://w3id.org/celine-eu#CommitmentMode"/>
        <rdfs:comment>Commitment activated manually by the member at their discretion.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/celine-eu"/>
        <skos:prefLabel>Voluntary</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/celine-eu#CommitmentMode"/>
    </owl:NamedIndividual>
