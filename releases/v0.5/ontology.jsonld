  "@id" : "https://purl.org/peco/peco-core#EnergyCommunity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "https://w3id.org/celine-eu",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-03-24"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "The CELINE Core Ontology is a lightweight orchestration profile for\n    Renewable Energy Communities (RECs) and Digital Twin workflows. It connects established\n    standards — PECO, SAREF, SAREF4ENER, SOSA/SSN — without redefining their domain\n    semantics, providing a minimal coordination layer for simulation scenarios, dataset\n    references, KPI definition and evaluation, and REC flexibility commitment and settlement."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-05-05"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "CELINE Core Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "celine"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "https://w3id.org/celine-eu#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Version 0.5 introduces a generic, REC-centric KPI container (KPIDefinition,\n    KPICatalog, KPIScope, KPICalculationMethod, KPITemporalGranularity) and removes the direct\n    BIGG and BIGG4KPI imports. KPI alignment to external vocabularies (BIGG, SAREF, SAREF4ENER,\n    SOSA) is now expressed via SKOS mapping annotations on KPI classes rather than via OWL\n    imports. Existing KPIEvaluation usage is preserved with mandatory\n    linkage to a KPIDefinition."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "CELINE Core Ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://celine-eu.github.io/"
  }, {
    "@id" : "https://github.com/celine-eu"
  }, {
    "@id" : "https://www.celineproject.eu/"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "https://purl.org/peco/peco-core"
  }, {
    "@id" : "https://raw.githubusercontent.com/w3c/sdw/dee1bdd3c339d8a0ab512c7f9bc97a08912ad7d6/ssn/integrated/sosa.ttl"
  }, {
    "@id" : "https://saref.etsi.org/core/v3.1.1/saref.ttl"
  }, {
    "@id" : "https://saref.etsi.org/saref4ener/v1.2.1/saref4ener.ttl"
  } ],
  "http://www.w3.org/2002/07/owl#priorVersion" : [ {
    "@id" : "https://w3id.org/celine-eu/v0.4"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/celine-eu/v0.5"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.5.0"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#AdminCost",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://www.w3.org/2004/02/skos/core#Concept" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Overhead and management costs for operating the REC."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/celine-eu#CostType"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@value" : "Administrative Cost"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://w3id.org/celine-eu#CostType"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#Automated",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://www.w3.org/2004/02/skos/core#Concept" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Commitment fulfilled automatically by a smart device or control system, without manual intervention from the member."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/celine-eu#CommitmentMode"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@value" : "Automated"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://w3id.org/celine-eu#CommitmentMode"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#CommitmentMode",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Classification of how a flexibility commitment is activated."
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Commitment Mode"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@value" : "Commitment Mode"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#CommunityContext",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Operational context binding a PECO Energy Community\n    with assets, datasets, simulations and flexibility commitments."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Community Context"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:ctx1 a celine:CommunityContext ;\n    celine:hasCommunity    ex:rec_valdarno ;\n    celine:usesAsset       ex:pv_panel_01 ;\n    celine:hasSimulation   ex:sim_baseline ;\n    celine:hasCommitment   ex:fc_001 ;\n    celine:hasSettlementRun ex:sr_2025_q3 ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#ConstraintType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Classification of operational constraints on flexibility activation."
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Constraint Type"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@value" : "Constraint Type"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#CostItem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A named cost voice within a SettlementRun (e.g., administrative fee,\n    platform fee, outstanding debt). Enables transparent cost breakdown before redistribution\n    amounts are finalised."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Cost Item"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:cost_admin a celine:CostItem ;\n    celine:hasCostType  celine:AdminCost ;\n    dct:description     \"Community administration fee Q3 2025\" ;\n    celine:costAmount   \"120.00\"^^xsd:decimal .\n\nex:cost_platform_fee a celine:CostItem ;\n    celine:hasCostType  celine:Fee ;\n    dct:description     \"CELINE platform usage fee Q3 2025\" ;\n    celine:costAmount   \"45.00\"^^xsd:decimal ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#CostType",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Classification of cost voices within a SettlementRun."
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
