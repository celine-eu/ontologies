}, {
  "@id" : "https://w3id.org/celine-eu#FlexibilityActivated",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://www.w3.org/2004/02/skos/core#Concept" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/celine-eu#KPIDefinition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Flessibilità attivata"
  }, {
    "@language" : "en",
    "@value" : "Flexibility Activated"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Total flexibility energy activated (delivered) during the evaluation period, across all commitments in scope."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/celine-eu#KPICatalog"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://w3id.org/celine-eu#KPICatalog"
  } ],
  "https://w3id.org/celine-eu#hasKPICalculationMethod" : [ {
    "@id" : "https://w3id.org/celine-eu#MethodTotal"
  } ],
  "https://w3id.org/celine-eu#hasKPIName" : [ {
    "@value" : "Flexibility Activated"
  } ],
  "https://w3id.org/celine-eu#hasKPIScopeType" : [ {
    "@id" : "https://w3id.org/celine-eu#ScopeCommunity"
  } ],
  "https://w3id.org/celine-eu#hasKPITemporalGranularity" : [ {
    "@id" : "https://w3id.org/celine-eu#GranularityPeriod"
  } ],
  "https://w3id.org/celine-eu#hasKPIUnit" : [ {
    "@id" : "https://w3id.org/celine-eu#KilowattHour"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#FlexibilityCommitment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A member's pledge to provide a specific amount of flexibility\n    on one or more of their PODs during a given time window. The commitment can be\n    automated (device-driven) or voluntary (manually activated by the member)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Flexibility Commitment"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:fc_001 a celine:FlexibilityCommitment ;\n    celine:committedBy              ex:member_rossi ;\n    celine:onPOD                    ex:pod_rossi_heatpump ;\n    celine:hasCommitmentMode        celine:Automated ;\n    celine:hasFlexibilityDirection  celine:FlexDown ;\n    celine:targetFlexibility        \"2.5\"^^xsd:decimal ;\n    celine:hasTimeInterval          ex:interval_2025_07_01 ;\n    celine:generatesCredit          ex:cr_001 ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#FlexibilityConstraint",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Operational constraint governing when and how flexibility declared in a\n    FlexibilityEnvelope may be activated. Encodes timing rules (minimum notice period, minimum\n    and maximum activation duration, recovery time between activations) and frequency limits."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Flexibility Constraint"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:constraint_hp a celine:FlexibilityConstraint ;\n    celine:hasConstraintType     celine:DurationConstraint ;\n    celine:minNotificationTime   \"PT15M\"^^xsd:duration ;\n    celine:minActivationDuration \"PT30M\"^^xsd:duration ;\n    celine:maxActivationDuration \"PT4H\"^^xsd:duration ;\n    celine:minRecoveryTime       \"PT1H\"^^xsd:duration ;\n    celine:maxActivationsPerDay  \"3\"^^xsd:integer ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#FlexibilityCredit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Credit awarded to a member for fulfilling (fully or partially)\n    a FlexibilityCommitment. Denominated in kWh and backed by metered SOSA observations.\n    Credits accumulate until reconciled in a SettlementRun."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Flexibility Credit"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:cr_001 a celine:FlexibilityCredit ;\n    celine:earnedBy     ex:member_rossi ;\n    celine:creditFor    ex:fc_001 ;\n    celine:creditAmount \"2.1\"^^xsd:decimal ;\n    celine:evidencedBy  ex:obs_pod_rossi_20250701T10 ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#FlexibilityDirection",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Direction of the flexibility commitment relative to the community baseline."
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#ConceptScheme"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Flexibility Direction"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@value" : "Flexibility Direction"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#FlexibilityEnvelope",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Declared capability of a Point of Delivery (POD) to provide flexibility\n    within a given availability window. Captures the physical bounds — maximum upward and downward\n    power and available energy — that constrain any FlexibilityCommitment drawn from it.\n    Aligned with saref4ener:PowerProfile for device-level scheduling semantics."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Flexibility Envelope"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://saref.etsi.org/saref4ener/"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:env_hp a celine:FlexibilityEnvelope ;\n    celine:envelopeFor           ex:pod_rossi_heatpump ;\n    celine:maxFlexUp             \"2.0\"^^xsd:decimal ;\n    celine:maxFlexDown           \"3.0\"^^xsd:decimal ;\n    celine:availableEnergy       \"6.0\"^^xsd:decimal ;\n    celine:hasAvailabilityWindow ex:window_morning ;\n    celine:hasConstraint         ex:constraint_hp ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#FrequencyConstraint",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://www.w3.org/2004/02/skos/core#Concept" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Constraint on the maximum number of flexibility activations permitted within a given period."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/celine-eu#ConstraintType"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@value" : "Frequency Constraint"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://w3id.org/celine-eu#ConstraintType"
  } ]
