}, {
  "@id" : "https://w3id.org/celine-eu#RedistributionResult",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The calculated redistribution outcome for a single member within a\n    SettlementRun. Records credit balance (kWh), gross monetary value before deductions,\n    the member's allocated share of community costs, and the final net amount."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Redistribution Result"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:result_rossi a celine:RedistributionResult ;\n    celine:resultFor        ex:member_rossi ;\n    celine:creditBalance    \"2.1\"^^xsd:decimal ;\n    celine:grossAmount      \"0.252\"^^xsd:decimal ;\n    celine:costDeduction    \"0.048\"^^xsd:decimal ;\n    celine:netAmount        \"0.204\"^^xsd:decimal ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#Scenario",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Definition of assumptions, temporal scope and configuration\n    for one or more simulations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Scenario"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:sc_summer a celine:Scenario ;\n    rdfs:label              \"Summer 2025 baseline\" ;\n    dct:description         \"24-hour simulation with historical irradiance data.\" ;\n    celine:hasTimeInterval  ex:interval_2025_summer ."
  } ]
}, {
