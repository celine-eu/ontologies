  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@value" : "Cost Type"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#DatasetReference",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Reference to an external dataset used as input or produced as output.\n    CELINE does not define dataset schemas."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Dataset Reference"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:ds_irradiance a celine:DatasetReference ;\n    dct:identifier  \"irradiance-2025-07\" ;\n    dct:source      <https://data.example.org/weather/irradiance> ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#Debt",
