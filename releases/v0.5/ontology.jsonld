    "@id" : "https://w3id.org/celine-eu#KPICatalog"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://w3id.org/celine-eu#KPICatalog"
  } ],
  "https://w3id.org/celine-eu#hasKPICalculationMethod" : [ {
    "@id" : "https://w3id.org/celine-eu#MethodRatio"
  } ],
  "https://w3id.org/celine-eu#hasKPIName" : [ {
    "@value" : "Self-Sufficiency Rate"
  } ],
  "https://w3id.org/celine-eu#hasKPIScopeType" : [ {
    "@id" : "https://w3id.org/celine-eu#ScopeCommunity"
  } ],
  "https://w3id.org/celine-eu#hasKPITemporalGranularity" : [ {
    "@id" : "https://w3id.org/celine-eu#GranularityPeriod"
  } ],
  "https://w3id.org/celine-eu#hasKPIUnit" : [ {
    "@id" : "https://w3id.org/celine-eu#Dimensionless"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#SettlementRun",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Execution of the redistribution calculation for a settlement period.\n    Aggregates FlexibilityCredits across all members, applies a linear conversion rate\n    (kWh -> monetary), deducts shared cost voices (CostItems), and produces one\n    RedistributionResult per member."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Settlement Run"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:sr_2025_q3 a celine:SettlementRun ;\n    celine:settlesContext           ex:ctx1 ;\n    celine:hasTimeInterval          ex:interval_q3_2025 ;\n    celine:conversionRate           \"0.12\"^^xsd:decimal ;\n    celine:currency                 \"EUR\" ;\n    celine:hasCostItem              ex:cost_admin, ex:cost_platform_fee ;\n    celine:hasRedistributionResult  ex:result_rossi, ex:result_bianchi ."
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#SharedEnergy",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://www.w3.org/2004/02/skos/core#Concept" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/celine-eu#KPIDefinition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Energia condivisa"
  }, {
    "@language" : "en",
    "@value" : "Shared Energy"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Total energy shared within the community during the evaluation period, as defined by the Italian ARERA regulation for RECs."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://w3id.org/celine-eu#KPICatalog"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://w3id.org/celine-eu#KPICatalog"
  } ],
  "https://w3id.org/celine-eu#hasKPICalculationMethod" : [ {
    "@id" : "https://w3id.org/celine-eu#MethodTotal"
  } ],
  "https://w3id.org/celine-eu#hasKPIName" : [ {
    "@value" : "Shared Energy"
  } ],
  "https://w3id.org/celine-eu#hasKPIScopeType" : [ {
    "@id" : "https://w3id.org/celine-eu#ScopeCommunity"
  } ],
  "https://w3id.org/celine-eu#hasKPITemporalGranularity" : [ {
    "@id" : "https://w3id.org/celine-eu#GranularityPeriod"
  } ],
  "https://w3id.org/celine-eu#hasKPIUnit" : [ {
    "@id" : "https://w3id.org/celine-eu#KilowattHour"
  } ]
}, {
