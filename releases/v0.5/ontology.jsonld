}, {
  "@id" : "https://w3id.org/celine-eu#KPIDefinition",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A definition of a KPI type, independent of any specific evaluation.\n    Captures the name, description, formula, unit, scope, calculation method and temporal\n    granularity of a KPI. Instances may simultaneously be skos:Concept members of the\n    celine:KPICatalog controlled vocabulary."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Definizione KPI"
  }, {
    "@language" : "en",
    "@value" : "KPI Definition"
  } ],
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "https://saref.etsi.org/saref4city/KeyPerformanceIndicator"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:kpi_def_ssr a celine:KPIDefinition , skos:Concept ;\n    skos:inScheme           celine:KPICatalog ;\n    celine:hasKPIName       \"Self-Sufficiency Rate\" ;\n    celine:hasKPIDescription \"Ratio of locally consumed energy to total consumption.\"@en ;\n    celine:hasKPIScopeType           celine:ScopeCommunity ;\n    celine:hasKPICalculationMethod   celine:MethodRatio ;\n    celine:hasKPITemporalGranularity celine:GranularityPeriod ;\n    celine:hasKPIUnit                celine:Dimensionless ."
  } ],
  "http://www.w3.org/2004/02/skos/core#relatedMatch" : [ {
    "@id" : "http://bigg-project.eu/bigg4kpi#BuildingKeyPerformanceIndicator"
  } ]
}, {
  "@id" : "https://w3id.org/celine-eu#KPIEvaluation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Evaluation of a KPI for a specific scope entity and time interval.\n    References a KPIDefinition for the metric type, and carries the computed value,\n    the evaluation period, and optional provenance links to observations or upstream\n    KPI evaluations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/celine-eu"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "KPI Evaluation"
  }, {
    "@language" : "it",
    "@value" : "Valutazione KPI"
  } ],
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "http://bigg-project.eu/bigg4kpi#KPIAssessment"
  }, {
    "@id" : "https://saref.etsi.org/saref4city/KeyPerformanceIndicatorAssessment"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@value" : "ex:kpi_eval_ssr_q3 a celine:KPIEvaluation ;\n    celine:hasKPIDefinition        celine:SelfSufficiencyRate ;\n    celine:hasKPIValue             \"0.72\"^^xsd:decimal ;\n    celine:hasEvaluationTimeInterval ex:interval_q3_2025 ;\n    celine:hasEvaluatedScope       ex:ctx1 ;\n    celine:hasInputObservation     ex:obs_meter_001 ."
  } ]
