###  https://w3id.org/celine-eu#Kilowatt
:Kilowatt rdf:type owl:NamedIndividual ,
                   <http://www.w3.org/2004/02/skos/core#Concept> ;
          rdfs:comment "Unit of power equal to 1000 watts. UCUM code: kW"@en ;
          rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
          <http://www.w3.org/2004/02/skos/core#inScheme> :UnitOfMeasure ;
          <http://www.w3.org/2004/02/skos/core#notation> "kW" ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "Kilowatt"@en ,
                                                          "Kilowatt"@it ;
          <http://www.w3.org/2004/02/skos/core#topConceptOf> :UnitOfMeasure .


###  https://w3id.org/celine-eu#KilowattHour
:KilowattHour rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/2004/02/skos/core#Concept> ;
              rdfs:comment "Unit of energy equal to 3.6 MJ. UCUM code: kW.h"@en ;
              rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
              <http://www.w3.org/2004/02/skos/core#inScheme> :UnitOfMeasure ;
              <http://www.w3.org/2004/02/skos/core#notation> "kW.h" ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Kilowatt-hour"@en ,
                                                              "Kilowattora"@it ;
              <http://www.w3.org/2004/02/skos/core#topConceptOf> :UnitOfMeasure .


###  https://w3id.org/celine-eu#LocalGenerationEnergy
:LocalGenerationEnergy rdf:type owl:NamedIndividual ,
                                <http://www.w3.org/2004/02/skos/core#Concept> ,
                                :KPIDefinition ;
                       :hasKPICalculationMethod :MethodTotal ;
                       :hasKPIScopeType :ScopeCommunity ;
                       :hasKPITemporalGranularity :GranularityPeriod ;
                       :hasKPIUnit :KilowattHour ;
                       :hasKPIName "Local Generation Energy" ;
