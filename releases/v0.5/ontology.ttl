                       <http://www.w3.org/2004/02/skos/core#inScheme> :KPICatalog ;
                       <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICatalog .


###  https://w3id.org/celine-eu#MethodAverage
:MethodAverage rdf:type owl:NamedIndividual ,
                        <http://www.w3.org/2004/02/skos/core#Concept> ;
               rdfs:comment "Arithmetic mean of all values over the evaluation period."@en ;
               rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
               <http://www.w3.org/2004/02/skos/core#inScheme> :KPICalculationMethod ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Average"@en ,
                                                               "Media"@it ;
               <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICalculationMethod .


