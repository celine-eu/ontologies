              rdfs:label "Energia condivisa"@it ,
                         "Shared Energy"@en ;
              <http://www.w3.org/2004/02/skos/core#definition> "Total energy shared within the community during the evaluation period, as defined by the Italian ARERA regulation for RECs."@en ;
              <http://www.w3.org/2004/02/skos/core#inScheme> :KPICatalog ;
              <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICatalog .


