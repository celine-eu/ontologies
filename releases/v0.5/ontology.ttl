###  https://w3id.org/celine-eu#IncentiveAccrued
:IncentiveAccrued rdf:type owl:NamedIndividual ,
                           <http://www.w3.org/2004/02/skos/core#Concept> ,
                           :KPIDefinition ;
                  :hasKPICalculationMethod :MethodTotal ;
                  :hasKPIScopeType :ScopeCommunity ;
                  :hasKPITemporalGranularity :GranularityPeriod ;
                  :hasKPIUnit :Euro ;
                  :hasKPIName "Incentive Accrued" ;
                  rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
                  rdfs:label "Incentive Accrued"@en ,
                             "Incentivo maturato"@it ;
                  <http://www.w3.org/2004/02/skos/core#definition> "Total monetary incentive accrued by the community for shared energy during the evaluation period."@en ;
                  <http://www.w3.org/2004/02/skos/core#inScheme> :KPICatalog ;
                  <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICatalog .


###  https://w3id.org/celine-eu#IncentiveMemberShare
:IncentiveMemberShare rdf:type owl:NamedIndividual ,
                               <http://www.w3.org/2004/02/skos/core#Concept> ,
                               :KPIDefinition ;
                      :hasKPICalculationMethod :MethodTotal ;
                      :hasKPIScopeType :ScopeMember ;
                      :hasKPITemporalGranularity :GranularityPeriod ;
                      :hasKPIUnit :Euro ;
                      :hasKPIName "Incentive Member Share" ;
                      rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
                      rdfs:label "Incentive Member Share"@en ,
                                 "Quota incentivo membro"@it ;
                      <http://www.w3.org/2004/02/skos/core#definition> "Share of the community's accrued incentive attributed to an individual member during the evaluation period."@en ;
                      <http://www.w3.org/2004/02/skos/core#inScheme> :KPICatalog ;
                      <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICatalog .


###  https://w3id.org/celine-eu#KPICalculationMethod
:KPICalculationMethod rdf:type owl:NamedIndividual ,
                               <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                      <http://purl.org/dc/terms/description> "Classification of the mathematical method used to compute a KPI value."@en ;
                      rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
                      rdfs:label "KPI Calculation Method"@en ,
                                 "Metodo di calcolo KPI"@it ;
                      <http://www.w3.org/2004/02/skos/core#hasTopConcept> :MethodAverage ,
                                                                          :MethodDerived ,
                                                                          :MethodInstantaneous ,
                                                                          :MethodMaximum ,
                                                                          :MethodMinimum ,
                                                                          :MethodOther ,
                                                                          :MethodRatio ,
                                                                          :MethodTotal ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "KPI Calculation Method"@en .


###  https://w3id.org/celine-eu#KPICatalog
:KPICatalog rdf:type owl:NamedIndividual ,
                     <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
            <http://purl.org/dc/terms/description> """Controlled vocabulary of named, REC-relevant KPI definitions.
    Each member is both a skos:Concept and a celine:KPIDefinition."""@en ;
            rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
            rdfs:label "Catalogo KPI"@it ,
                       "KPI Catalog"@en ;
            <http://www.w3.org/2004/02/skos/core#hasTopConcept> :FedInEnergy ,
                                                                :FlexibilityActivated ,
                                                                :IncentiveAccrued ,
                                                                :IncentiveMemberShare ,
                                                                :LocalGenerationEnergy ,
                                                                :PeakReductionAchieved ,
                                                                :SelfConsumptionRate ,
                                                                :SelfSufficiencyRate ,
                                                                :SharedEnergy ,
                                                                :SharedEnergyMemberShare ,
                                                                :WithdrawnEnergy ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "KPI Catalog"@en .


###  https://w3id.org/celine-eu#KPIScope
:KPIScope rdf:type owl:NamedIndividual ,
                   <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
