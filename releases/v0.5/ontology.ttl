:MethodDerived rdf:type owl:NamedIndividual ,
                        <http://www.w3.org/2004/02/skos/core#Concept> ;
               rdfs:comment "Value computed from one or more upstream KPI evaluations."@en ;
               rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
               <http://www.w3.org/2004/02/skos/core#inScheme> :KPICalculationMethod ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Derivato"@it ,
