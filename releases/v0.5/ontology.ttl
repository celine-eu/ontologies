:MethodMaximum rdf:type owl:NamedIndividual ,
                        <http://www.w3.org/2004/02/skos/core#Concept> ;
               rdfs:comment "Highest observed value over the evaluation period."@en ;
               rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
               <http://www.w3.org/2004/02/skos/core#inScheme> :KPICalculationMethod ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Massimo"@it ,
                                                               "Maximum"@en ;
               <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICalculationMethod .


###  https://w3id.org/celine-eu#MethodMinimum
:MethodMinimum rdf:type owl:NamedIndividual ,
                        <http://www.w3.org/2004/02/skos/core#Concept> ;
               rdfs:comment "Lowest observed value over the evaluation period."@en ;
               rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
               <http://www.w3.org/2004/02/skos/core#inScheme> :KPICalculationMethod ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Minimo"@it ,
                                                               "Minimum"@en ;
               <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICalculationMethod .


###  https://w3id.org/celine-eu#MethodOther
:MethodOther rdf:type owl:NamedIndividual ,
                      <http://www.w3.org/2004/02/skos/core#Concept> ;
             rdfs:comment "Calculation method that does not fit the predefined categories."@en ;
             rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
             <http://www.w3.org/2004/02/skos/core#inScheme> :KPICalculationMethod ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Altro"@it ,
                                                             "Other"@en ;
             <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICalculationMethod .


###  https://w3id.org/celine-eu#MethodRatio
:MethodRatio rdf:type owl:NamedIndividual ,
                      <http://www.w3.org/2004/02/skos/core#Concept> ;
             rdfs:comment "Quotient of two quantities, typically expressed as a fraction or percentage."@en ;
             rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
             <http://www.w3.org/2004/02/skos/core#inScheme> :KPICalculationMethod ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Rapporto"@it ,
                                                             "Ratio"@en ;
             <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICalculationMethod .


###  https://w3id.org/celine-eu#MethodTotal
:MethodTotal rdf:type owl:NamedIndividual ,
                      <http://www.w3.org/2004/02/skos/core#Concept> ;
             rdfs:comment "Summation of all values over the evaluation period."@en ;
             rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
             <http://www.w3.org/2004/02/skos/core#inScheme> :KPICalculationMethod ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Total"@en ,
                                                             "Totale"@it ;
             <http://www.w3.org/2004/02/skos/core#topConceptOf> :KPICalculationMethod .


###  https://w3id.org/celine-eu#NoticeConstraint
:NoticeConstraint rdf:type owl:NamedIndividual ,
                           <http://www.w3.org/2004/02/skos/core#Concept> ;
                  rdfs:comment "Constraint on the minimum lead time required before activating flexibility." ;
                  rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
                  <http://www.w3.org/2004/02/skos/core#inScheme> :ConstraintType ;
                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Notice Constraint" ;
                  <http://www.w3.org/2004/02/skos/core#topConceptOf> :ConstraintType .


###  https://w3id.org/celine-eu#PeakReductionAchieved
:PeakReductionAchieved rdf:type owl:NamedIndividual ,
                                <http://www.w3.org/2004/02/skos/core#Concept> ,
                                :KPIDefinition ;
                       :hasKPICalculationMethod :MethodTotal ;
                       :hasKPIScopeType :ScopeCommunity ;
                       :hasKPITemporalGranularity :GranularityPeriod ;
                       :hasKPIUnit :Kilowatt ;
                       :hasKPIName "Peak Reduction Achieved" ;
                       rdfs:isDefinedBy <https://w3id.org/celine-eu> ;
