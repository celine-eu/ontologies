    { "@id": "celine:hasCommitmentMode",     "@type": "owl:ObjectProperty", "label": "has commitment mode" },
    { "@id": "celine:hasFlexibilityDirection","@type": "owl:ObjectProperty", "label": "has flexibility direction" },
    { "@id": "celine:generatesCredit",       "@type": "owl:ObjectProperty", "label": "generates credit" },
