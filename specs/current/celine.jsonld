  "@graph": [
    {
      "@id": "https://w3id.org/celine-eu",
      "@type": "owl:Ontology",
      "label": "CELINE Core Ontology",
      "description": "Lightweight orchestration ontology for Renewable Energy Communities and Digital Twin workflows. CELINE integrates PECO, SAREF, SOSA and BIGG without redefining domain semantics. v0.4 adds REC flexibility commitment and settlement modelling.",
      "dct:license": { "@id": "https://creativecommons.org/licenses/by/4.0/" }
    },
