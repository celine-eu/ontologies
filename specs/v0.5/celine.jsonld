    { "@id": "celine:KPIEvaluation",     "@type": "owl:Class", "label": "KPI Evaluation" },
    { "@id": "celine:FlexibilityCommitment", "@type": "owl:Class", "label": "Flexibility Commitment" },
    { "@id": "celine:FlexibilityCredit",     "@type": "owl:Class", "label": "Flexibility Credit" },
