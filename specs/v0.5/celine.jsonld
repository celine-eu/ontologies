      "@id": "https://w3id.org/celine-eu",
      "@type": "owl:Ontology",
      "label": "CELINE Core Ontology",
      "description": "Lightweight orchestration ontology for Renewable Energy Communities and Digital Twin workflows. CELINE integrates PECO, SAREF, SOSA without redefining domain semantics. v0.5 introduces a generic KPI container (KPIDefinition, KPICatalog) and removes BIGG/BIGG4KPI imports in favour of SKOS alignment annotations.",
      "dct:license": { "@id": "https://creativecommons.org/licenses/by/4.0/" }
    },
